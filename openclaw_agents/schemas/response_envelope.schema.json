{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "response_envelope.schema.json",
  "title": "ResponseEnvelope",
  "type": "object",
  "required": [
    "task_id",
    "project_id",
    "agent",
    "status",
    "summary",
    "artifacts_out",
    "findings",
    "next_action",
    "risks",
    "trace"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "project_id": { "type": "string" },
    "agent": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "artifacts_out": { "type": "array" },
    "findings": { "type": "array" },
    "next_action": { "type": ["string", "object"] },
    "risks": { "type": "array" },
    "trace": { "type": "object" }
  },
  "additionalProperties": true
}


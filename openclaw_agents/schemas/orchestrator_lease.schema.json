{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestrator_lease.schema.json",
  "title": "Orchestrator Lease",
  "description": "Lease record ensuring singleton orchestrators work on at most one active project at a time.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "orchestrator_id",
    "lease_status",
    "active_project_id",
    "lease_owner_run_id",
    "lease_acquired_at",
    "lease_expires_at"
  ],
  "properties": {
    "orchestrator_id": {
      "type": "string",
      "enum": ["niobe", "morpheus"]
    },
    "lease_status": {
      "type": "string",
      "enum": ["FREE", "HELD", "EXPIRED", "RELEASING"]
    },
    "active_project_id": {
      "type": ["string", "null"]
    },
    "lease_owner_run_id": {
      "type": ["string", "null"]
    },
    "lease_acquired_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "lease_expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "released_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "release_reason": {
      "type": "string"
    },
    "renew_count": {
      "type": "integer",
      "minimum": 0
    }
  }
}

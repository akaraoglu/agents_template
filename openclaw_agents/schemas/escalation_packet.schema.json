{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "escalation_packet.schema.json",
  "title": "EscalationPacket",
  "type": "object",
  "required": [
    "reason",
    "owner_agent",
    "blocking_facts",
    "options_considered",
    "recommended_action"
  ],
  "properties": {
    "reason": { "type": "string" },
    "owner_agent": { "type": "string" },
    "blocking_facts": { "type": "array" },
    "options_considered": { "type": "array" },
    "recommended_action": { "type": "string" }
  },
  "additionalProperties": true
}


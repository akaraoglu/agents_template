{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_snapshot.schema.json",
  "title": "Project Snapshot",
  "description": "Persisted project state snapshot captured at safe boundaries for pause, resume, and recovery.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "project_id",
    "captured_at",
    "captured_by",
    "project_status",
    "current_phase",
    "open_tasks",
    "next_action",
    "workspace_ref",
    "artifact_refs",
    "latest_human_summary"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "captured_by": {
      "type": "string",
      "minLength": 1
    },
    "project_status": {
      "type": "string",
      "enum": [
        "NEW",
        "READY",
        "ACTIVE",
        "PAUSE_REQUESTED",
        "PAUSED",
        "WAITING_EXTERNAL",
        "WAITING_VERIFICATION",
        "BLOCKED",
        "DONE",
        "CANCELLED"
      ]
    },
    "current_phase": {
      "type": "string",
      "minLength": 1
    },
    "current_owner_agent": {
      "type": "string",
      "enum": [
        "master",
        "neo",
        "agent_smith",
        "niaobe",
        "architect",
        "morpheus",
        "oracle",
        "planner",
        "implementer",
        "tester"
      ]
    },
    "open_tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": true
    },
    "workspace_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "latest_human_summary": {
      "type": "string",
      "minLength": 1
    },
    "safe_boundary_type": {
      "type": "string",
      "enum": [
        "TASK_COMPLETED",
        "TASK_RESULT_PERSISTED",
        "ESCALATION_PERSISTED",
        "ORACLE_REPORT_PERSISTED",
        "MORPHEUS_DELIVERY_PERSISTED",
        "PROJECT_PLAN_PERSISTED",
        "PROJECT_STATUS_SNAPSHOT_PERSISTED"
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_schedule_record.schema.json",
  "title": "Project Schedule Record",
  "description": "Scheduler-facing per-project queue state and eligibility metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "queue_state",
    "eligible_for_scheduling",
    "pause_requested",
    "resume_requested",
    "preemption_allowed",
    "waiting_reason",
    "last_scheduled_at",
    "times_scheduled"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "queue_state": {
      "type": "string",
      "enum": [
        "urgent",
        "active_recovery",
        "normal_ready",
        "waiting_external",
        "blocked"
      ]
    },
    "eligible_for_scheduling": {
      "type": "boolean"
    },
    "pause_requested": {
      "type": "boolean"
    },
    "resume_requested": {
      "type": "boolean"
    },
    "preemption_allowed": {
      "type": "boolean"
    },
    "waiting_reason": {
      "type": ["string", "null"]
    },
    "last_scheduled_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "times_scheduled": {
      "type": "integer",
      "minimum": 0
    },
    "priority": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"]
    },
    "current_safe_boundary_type": {
      "type": "string",
      "enum": [
        "TASK_COMPLETED",
        "TASK_RESULT_PERSISTED",
        "ESCALATION_PERSISTED",
        "ORACLE_REPORT_PERSISTED",
        "MORPHEUS_DELIVERY_PERSISTED",
        "PROJECT_PLAN_PERSISTED",
        "PROJECT_STATUS_SNAPSHOT_PERSISTED"
      ]
    },
    "fairness_deadline_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}

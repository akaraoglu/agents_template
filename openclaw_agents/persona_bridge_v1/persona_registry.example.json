{
  "personas": {
    "agentsmith": {
      "display_name": "AgentSmith",
      "zuliprc_path": "./private/agentsmith-bot.zuliprc",
      "run_command": ["bash", ".agents/run_assistant.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "allow_dm": true,
      "allowed_streams": ["assistant", "council"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["agentsmith", "smith"],
      "description": "Main discussion-first assistant and control-plane front door."
    },
    "yoda": {
      "display_name": "Yoda",
      "zuliprc_path": "./private/yoda-bot.zuliprc",
      "run_command": ["bash", ".agents/run_yoda.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "allow_dm": true,
      "allowed_streams": ["council", "ideas"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["yoda", "master yoda"],
      "description": "Wise discussion persona for visible group conversation and direct questions."
    },
    "architect": {
      "display_name": "Architect",
      "zuliprc_path": "./private/architect-bot.zuliprc",
      "run_command": ["bash", ".agents/run_architect.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "allow_dm": true,
      "allowed_streams": ["assistant", "planning"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["architect"],
      "description": "Document-driven planning and management persona."
    }
  }
}

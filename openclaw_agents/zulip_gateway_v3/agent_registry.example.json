{
  "agents": {
    "agentsmith": {
      "display_name": "AgentSmith",
      "zuliprc_path": "./private/agentsmith-bot.zuliprc",
      "run_command": ["bash", ".agents/run_assistant.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "allow_dm": true,
      "allowed_streams": ["assistant", "projects", "software"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["agentsmith", "smith"],
      "loops": ["dispatch", "discussion"],
      "skills": ["clarify", "route", "handoff"],
      "can_handoff_to": ["neo", "yoda", "niaobe", "architect", "morpheus", "oracle"],
      "description": "Main discussion-first assistant and front door."
    },
    "neo": {
      "display_name": "Neo",
      "zuliprc_path": "./private/neo-bot.zuliprc",
      "run_command": ["bash", ".agents/run_neo.sh"],
      "workspace": "YOUR_NEO_WORKSPACE",
      "allow_dm": true,
      "allowed_streams": ["assistant", "projects", "software"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["neo", "cto"],
      "loops": ["discussion", "execution", "review"],
      "skills": ["implement", "review", "debug", "handoff"],
      "can_handoff_to": ["yoda", "niaobe", "architect", "morpheus", "oracle"],
      "description": "CTO-level direct-execution assistant backed by a host OpenClaw OAuth runtime."
    },
    "yoda": {
      "display_name": "Yoda",
      "zuliprc_path": "./private/yoda-bot.zuliprc",
      "run_command": ["bash", ".agents/run_yoda.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "allow_dm": true,
      "allowed_streams": ["assistant", "projects", "council"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["yoda", "master yoda"],
      "loops": ["discussion", "challenge", "review"],
      "skills": ["challenge", "reframe", "risk-review", "handoff"],
      "can_handoff_to": ["agentsmith", "niaobe", "architect"],
      "description": "Wise advisory role for critique, reframing, and strategic second opinions."
    },
    "niaobe": {
      "display_name": "Niaobe",
      "zuliprc_path": "./private/niaobe-bot.zuliprc",
      "run_command": ["bash", ".agents/run_projectmanager.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "bridge_instructions": "You own the project loop. Do not run product execution or validation yourself; hand planning, software, and validation work to the correct visible role. Ask one concrete question when blocked by a missing decision or missing scope.",
      "allow_dm": true,
      "allowed_streams": ["projects", "assistant"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["niaobe", "niobe", "project manager"],
      "loops": ["project"],
      "skills": ["project-plan", "project-decision", "handoff"],
      "can_handoff_to": ["architect", "morpheus", "oracle"],
      "description": "Project manager that keeps the project loop moving until completion or escalation."
    },
    "architect": {
      "display_name": "Architect",
      "zuliprc_path": "./private/architect-bot.zuliprc",
      "run_command": ["bash", ".agents/run_architect.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "bridge_instructions": "Return planning results to Niaobe. Do not hand off directly to Morpheus or Oracle from the project loop.",
      "allow_dm": true,
      "allowed_streams": ["projects", "assistant"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["architect"],
      "loops": ["planning"],
      "skills": ["milestones", "stories", "acceptance-criteria"],
      "can_handoff_to": ["niaobe"],
      "description": "Planning and documentation role for milestones, stories, tasks, and acceptance criteria."
    },
    "morpheus": {
      "display_name": "Morpheus",
      "zuliprc_path": "./private/morpheus-bot.zuliprc",
      "run_command": ["bash", ".agents/run_morpheus.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "bridge_instructions": "Use the internal software team and return the software execution result to Niaobe. Do not claim to spawn or coordinate other visible roles directly.",
      "allow_dm": true,
      "allowed_streams": ["software", "projects", "assistant"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["morpheus", "software team"],
      "loops": ["software"],
      "skills": ["plan", "implement", "test", "report"],
      "can_handoff_to": ["niaobe"],
      "description": "Visible software execution manager that fronts the planner/coder/tester team."
    },
    "oracle": {
      "display_name": "Oracle",
      "zuliprc_path": "./private/oracle-bot.zuliprc",
      "run_command": ["bash", ".agents/run_oracle.sh"],
      "workspace": "YOUR_AGENT_HOME",
      "bridge_instructions": "Return validation results to Niaobe unless the human explicitly asks for a direct standalone review.",
      "allow_dm": true,
      "allowed_streams": ["projects", "software", "assistant"],
      "reply_mode": "dm_or_mention",
      "mention_triggers": ["oracle", "qa", "validator"],
      "loops": ["validation"],
      "skills": ["validate", "evidence", "accept-or-reject"],
      "can_handoff_to": ["niaobe"],
      "description": "Independent validation and QA role."
    }
  }
}
